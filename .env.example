# ─────────────────────────────────────────────────────────────────────────────
# NIZAM-RUS Backend — Environment Configuration
# Copy this file to .env and fill in real values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="NIZAM-RUS"
APP_ENV=development           # development | production
FRONTEND_ORIGIN=http://localhost:5500   # Your frontend URL for CORS

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (dev):
DATABASE_URL=sqlite+aiosqlite:///./nizam_rus.db
# PostgreSQL (production — just swap the URL, no code changes needed):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/nizam_rus

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_super_secret_key_change_this_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60      # 1 hour
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Email Verification Token ──────────────────────────────────────────────────
VERIFICATION_TOKEN_EXPIRE_HOURS=24

# ── Email Provider (Resend) ───────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME="NIZAM-RUS"

# ── Email Provider (SMTP fallback) ────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_TLS=true
